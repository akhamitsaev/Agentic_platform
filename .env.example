# ========== База данных ==========
POSTGRES_USER=agent
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=agent_platform
DATABASE_URL=postgresql://agent:agentpass@postgres:5432/agent_platform

# ========== Авторизация ==========
MASTER_TOKEN=master-secret-token-2026
POET_AGENT_TOKEN=poet-agent-secret-token-2026
TRANSLATOR_AGENT_TOKEN=translator-agent-secret-token-2026

# ========== LLM Провайдеры ==========
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========== Балансировщик ==========
BALANCER_STRATEGY=latency

# ========== Мониторинг ==========
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
MLFLOW_TRACKING_URI=http://mlflow:5000
LLM_PROXY_URL=http://llm-proxy:8000

# ========== Grafana ==========
GF_SECURITY_ADMIN_PASSWORD=admin

# ========== Порты (для справки) ==========
# llm-proxy: 8000
# agent-registry: 8001
# provider-registry: 8002
# poet-agent: 8010
# literary-translator: 8011
# grafana: 3000
# prometheus: 9090
# mlflow: 5000
# postgres: 5432
# cadvisor: 8080